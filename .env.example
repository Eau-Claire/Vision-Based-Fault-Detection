# =====================================================================
# Vision-Based Fault Detection — Environment Configuration
# =====================================================================
# Copy this file to .env and fill in your values.
#
# DEVICE_PROFILE controls which model set and tuning parameters are used.
# Set to "pc" or "rasp" depending on your target device.
# =====================================================================

# ── Device Profile ──────────────────────────────────────────────────
# "pc"   → YOLOv8 + CNN (PyTorch), full pipeline, heavier
# "rasp" → CNN-only (ONNX), lightweight for Raspberry Pi
DEVICE_PROFILE=pc

# ── API Keys ────────────────────────────────────────────────────────
ROBOFLOW_API_KEY=YOUR_API_KEY_HERE

# ── Camera Source ───────────────────────────────────────────────────
# Use "0" for webcam, or an RTSP/HTTP stream URL
# IP_CAMERA_URL=http://192.168.1.x:8080/video
IP_CAMERA_URL=0

# ── Backend API ─────────────────────────────────────────────────────
OCELOT_GATEWAY_URL=http://localhost:5000
JWT_TOKEN=

# ── Metadata ────────────────────────────────────────────────────────
TOWER_ID=T-110KV-01
LATITUDE=21.0285
LONGITUDE=105.8542

# ── Model Paths (optional — auto-resolved from profile) ────────────
# Override these only if you want to use custom model files.
# By default, models are loaded from models/<profile>/ or models/.
# YOLO_MODEL_PATH=models/pc/weights.pt
# CNN_MODEL_PATH=models/rasp/best_model.onnx

# ── Inference Device ────────────────────────────────────────────────
# DEVICE=cpu        # or "cuda" for GPU (PC only)

# ── Server ──────────────────────────────────────────────────────────
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
