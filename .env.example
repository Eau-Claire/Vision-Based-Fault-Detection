# =====================================================================
# Dual-Runtime Vision-Based Fault Detection — Environment Config
# =====================================================================

# ── General Config ──
# Set to "edge" for Raspberry Pi / YOLO11 runtime, or "server" for PC / RF-DETR runtime
DEVICE_PROFILE=server

# ── Web Server Settings ──
SERVER_HOST=0.0.0.0
SERVER_PORT=8002

# ── RabbitMQ Configuration ──
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_HEARTBEAT=600

# ── Backend Callback & Auth ──
# ASP.NET Core backend base URL
CALLBACK_BASE_URL=https://uavpms.ddns.net
# Service key used for backend service-to-service auth header
AI_SERVICE_KEY=YOUR_SECURE_SERVICE_KEY

# ── Edge-specific Parameters (edge_raspberry) ──
YOLO_MODEL_PATH=models/yolo11/yolo11n.pt
YOLO_IMAGE_SIZE=640
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
YOLO_DEVICE=cpu
# Video frame sampling: process 1 in every N frames
FRAME_SAMPLE_INTERVAL=15

# ── Server-specific Parameters (server_pc) ──
RFDETR_MODEL_PATH=models/rf_detr/rf_detr_base.pth
RFDETR_IMAGE_SIZE=560
RFDETR_CONF_THRESHOLD=0.30
# Set to "cuda" for GPU acceleration, "cpu" for CPU, or "auto" to auto-detect
RFDETR_DEVICE=auto
# Video frame sampling (denser than edge)
SERVER_FRAME_SAMPLE_INTERVAL=5
