# =====================================================================
# Dual-Runtime Vision-Based Fault Detection - Environment Config
# =====================================================================

# General Config
DEVICE_PROFILE=server

# Web Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8002

# RabbitMQ Configuration
RABBITMQ_HOST=uav-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=CHANGE_ME_RABBITMQ_USER
RABBITMQ_PASS=CHANGE_ME_RABBITMQ_PASSWORD
RABBITMQ_HEARTBEAT=600
RABBITMQ_PREFETCH_COUNT=1

# RabbitMQ Queue Names
RABBITMQ_EXCHANGE=ai.analysis
EDGE_QUEUE_NAME=ai.analysis.edge.requested
SERVER_QUEUE_NAME=ai.analysis.server.requested
DEAD_LETTER_EXCHANGE=ai.analysis.dlx
DEAD_LETTER_QUEUE=ai.analysis.dead-letter

# Backend Callback & Auth
CALLBACK_BASE_URL=http://uav-gateway:8080
CALLBACK_PATH=/api/internal/ai-analysis/results
AI_SERVICE_KEY=CHANGE_ME_LONG_RANDOM_SERVICE_KEY
CALLBACK_MAX_RETRIES=3
CALLBACK_RETRY_BASE_DELAY=1.0
CALLBACK_RETRY_MAX_DELAY=30.0
CALLBACK_TIMEOUT=15

# Media Download
MEDIA_DOWNLOAD_TIMEOUT=60
MEDIA_MAX_SIZE_BYTES=524288000

# Detection Artifacts
AI_ARTIFACT_DIR=/tmp/vision-ai-artifacts
AI_ARTIFACT_URL_PATH=/artifacts
SERVER_AI_PUBLIC_BASE_URL=http://localhost:8002
AI_ARTIFACT_JPEG_QUALITY=90

# Edge-specific Parameters
YOLO_MODEL_PATH=models/yolo11/yolo11n.pt
YOLO_IMAGE_SIZE=640
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.45
YOLO_DEVICE=cpu
FRAME_SAMPLE_INTERVAL=15

# Server-specific Parameters
SERVER_INFERENCE_BACKEND=roboflow
HARNESS_CHECKPOINT_DIR=/tmp/vision-harness-checkpoints
HARNESS_WORKFLOW_REF=fake://evn-object-detection
ROBOFLOW_API_KEY=CHANGE_ME_ROBOFLOW_API_KEY
ROBOFLOW_API_URL=http://roboflow-inference:9001
ROBOFLOW_WORKSPACE_NAME=les-workspace-ijdwd
ROBOFLOW_WORKFLOW_ID=evn-object-detection-vevn-object-detection-cnyo0-2-yolo11n-t1-logic
ROBOFLOW_TIMEOUT=30
ROBOFLOW_MAX_RETRIES=2
ROBOFLOW_RETRY_BASE_DELAY=1.0
RFDETR_MODEL_PATH=models/rf_detr/rf_detr_base.pth
RFDETR_CONFIG_PATH=
RFDETR_IMAGE_SIZE=560
RFDETR_CONF_THRESHOLD=0.30
RFDETR_DEVICE=auto
SERVER_FRAME_SAMPLE_INTERVAL=5
MAX_FRAMES_PER_VIDEO=500
DEDUP_IOU_THRESHOLD=0.4
MAX_DETECTIONS_PER_CLASS=10

# Security
ALLOW_PRIVATE_IPS=false
RESTRICT_CALLBACK_TO_BASE_URL=true

# Production deployment
PMS_DOCKER_NETWORK=uavpms_org_default
ROBOFLOW_INFERENCE_VERSION=1.3.6
CORE_MODEL_GAZE_ENABLED=false
ALLOW_CUSTOM_PYTHON_EXECUTION_IN_WORKFLOWS=true
